<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/img_control_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@android:color/black" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_device_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:text="Tên máy tính" />

            <TextView
                android:id="@+id/tv_device_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B3FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="40dp"
                android:text="192.168.x.x" />

            <!-- KHỐI ÂM LƯỢNG KÍNH MỜ CÓ PREVIEW SỐ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_border"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tv_vol_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ÂM LƯỢNG MÁY TÍNH: 50%"
                    android:textColor="#88FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <SeekBar
                    android:id="@+id/sb_volume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#FFFFFF"
                    android:thumbTint="#00E676" />
            </LinearLayout>

            <!-- KHỐI NGUỒN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_border"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NGUỒN &amp; HỆ THỐNG" android:textColor="#88FFFFFF" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="12dp">
                    <LinearLayout android:id="@+id/btn_off" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/glass_border" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔴" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tắt máy" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btn_lock" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/glass_border" android:layout_marginEnd="4dp" android:layout_marginStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Khóa" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btn_sleep" android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/glass_border" android:layout_marginStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌙" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngủ" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- KHỐI 3 NÚT MỚI: BẬT - HẸN GIỜ - HỦY LỆNH -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3">
                    <LinearLayout android:id="@+id/btn_wake" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center" android:background="@drawable/glass_border" android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟢 BẬT" android:textColor="#00E676" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btn_timer" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center" android:background="@drawable/glass_border" android:layout_marginEnd="2dp" android:layout_marginStart="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏱️ HẸN GIỜ" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/btn_abort" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="center" android:background="@drawable/glass_border" android:layout_marginStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❌ HỦY LỆNH" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- CÁC NÚT TÍNH NĂNG NÂNG CAO -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stealth_webcam"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="📸  CHỤP LÉN WEBCAM"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E040FB"
                app:backgroundTint="#26E040FB"
                app:strokeColor="#4DE040FB"
                app:strokeWidth="1dp"
                app:cornerRadius="24dp"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_monitor"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="💻  BẬT TASK MANAGER"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#69F0AE"
                app:backgroundTint="#2600E676"
                app:strokeColor="#4D00E676"
                app:strokeWidth="1dp"
                app:cornerRadius="24dp"
                android:layout_marginBottom="40dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>