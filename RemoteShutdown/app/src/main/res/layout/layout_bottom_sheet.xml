<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#212121">

    <!-- Header thông tin máy -->
    <TextView
        android:id="@+id/tv_sheet_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:text="Tên máy tính" />
    <TextView
        android:id="@+id/tv_sheet_ip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#BDBDBD"
        android:layout_marginBottom="20dp"
        android:text="192.168.1.1" />

    <!-- PHÂN LUỒNG 1: CỤM ÂM LƯỢNG -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CỤM ÂM LƯỢNG MEDIA"
        android:textColor="#888888"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="20dp">
        <Button
            android:id="@+id/btn_vol_down"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="GIẢM (-)"
            android:backgroundTint="#455A64"
            android:textColor="#FFFFFF" />
        <Button
            android:id="@+id/btn_vol_mute"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="MUTE"
            android:backgroundTint="#5D4037"
            android:textColor="#FFFFFF" />
        <Button
            android:id="@+id/btn_vol_up"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="TĂNG (+)"
            android:backgroundTint="#455A64"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- PHÂN LUỒNG 2: CỤM NGUỒN & HỆ THỐNG -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CỤM NGUỒN &amp; HỆ THỐNG"
        android:textColor="#888888"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="8dp">
        <Button
            android:id="@+id/btn_lock"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="KHOÁ"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF" />
        <Button
            android:id="@+id/btn_sleep"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:layout_marginStart="2dp"
            android:text="NGỦ"
            android:backgroundTint="#F57C00"
            android:textColor="#FFFFFF" />
        <Button
            android:id="@+id/btn_hibernate"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="ĐÔNG"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="20dp">
        <Button
            android:id="@+id/btn_shutdown"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="TẮT MÁY"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>
        <Button
            android:id="@+id/btn_abort"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="HUỶ LỆNH"
            android:backgroundTint="#388E3C"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- PHÂN LUỒNG 3: CỤM THÔNG BÁO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CỤM THÔNG BÁO TỪ XA"
        android:textColor="#888888"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:hint="Nhập nội dung..."
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:background="#333333"
            android:padding="8dp" />
        <Button
            android:id="@+id/btn_send_msg"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:text="GỬI ĐI"
            android:backgroundTint="#E91E63"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</LinearLayout>