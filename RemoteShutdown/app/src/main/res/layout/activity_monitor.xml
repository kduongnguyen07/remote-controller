<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:fitsSystemWindows="true"
    android:padding="16dp">

    <!-- Header y hệt Win 11 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CPU" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
        <TextView android:id="@+id/tv_cpu_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đang lấy thông số..." android:textColor="#CCCCCC" android:textSize="12sp" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
    </RelativeLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="% Utilization" android:textColor="#888888" android:textSize="12sp" android:layout_marginBottom="4dp"/>

    <!-- Biểu đồ có lưới (Grid) -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/chart_cpu"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginBottom="24dp"/>

    <!-- Bảng thông số chi tiết bên dưới -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Utilization" android:textColor="#888888" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_util" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textColor="#FFFFFF" android:textSize="20sp" android:layout_marginBottom="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Processes" android:textColor="#888888" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_procs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RAM Used" android:textColor="#888888" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_ram" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 GB" android:textColor="#FFFFFF" android:textSize="20sp" android:layout_marginBottom="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Threads" android:textColor="#888888" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_threads" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Up time" android:textColor="#888888" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_uptime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0:00:00" android:textColor="#FFFFFF" android:textSize="20sp" android:layout_marginBottom="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GPU RTX" android:textColor="#888888" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_gpu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0% - 0°C" android:textColor="#FFFFFF" android:textSize="16sp"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>